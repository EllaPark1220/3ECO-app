      "parameters": {
        "jsCode": "const text = $input.first().json.content || '';\nconst violations = [];\n\n// G1 — 회피 영역 키워드 (부분 문자열 오탐 방지: 앞에 한글이 오면 제외)\nconst avoidKeywords = ['군 복무','군대','징병','페미','젠더','좌파','우파','진보','보수','정권',\n  '영호남','부부','자녀','아내','남편','결혼','장기 매매','마약','최저임금'];\nfor (const kw of avoidKeywords) {\n  const count = (text.match(new RegExp('(?<![가-힣])' + kw, 'g')) || []).length;\n  if (count > 0) violations.push({ rule: 'G1_회피영역', term: kw, count });\n}\n// G2 — 번역체 8종 (자동 차단)\nconst translationese = ['매우','대단히','그것은','에 의해','결국에는','결국','을 가지고','를 가지고','에 대하여'];\nfor (const kw of translationese) {\n  const count = (text.match(new RegExp(kw, 'g')) || []).length;\n  if (count > 0) violations.push({ rule: 'G2_번역체', term: kw, count });\n}\n\n// G3 — 금지 표현: 단정·자극\nconst banned = ['충격','절대','무조건','확실히'];\nfor (const kw of banned) {\n  const count = (text.match(new RegExp(kw, 'g')) || []).length;\n  if (count > 0) violations.push({ rule: 'G3_금지표현', term: kw, count });\n}\n// '반드시'·'보장'은 단정 어미와 붙을 때만 위반\nconst assertive = (text.match(/(반드시|보장)[^.]{0,15}(됩니다|입니다)\\./g) || []).length;\nif (assertive > 0) violations.push({ rule: 'G3_금지표현', term: '단정 표현', count: assertive });\n\n// G4 — 학자명: 위반 아님. 마스터 운영 규칙의 세 조건\n// (반전 일화 / 그 인물 없이 설명이 어색 / 흥미로운 실험·사건) 판단이 필요하므로\n// 자동 차단하지 않고 게이트1에서 사람이 판단하도록 플래그만 올린다.\nconst scholars = ['애덤 스미스','케인즈','마르크스','리카도','프리드먼','슘페터','하이에크'];\nconst scholarFlags = [];\nfor (const kw of scholars) {\n  const count = (text.match(new RegExp(kw, 'g')) || []).length;\n  if (count > 0) scholarFlags.push({ term: kw, count });\n}\n\n// G5 — 분량 4,300 ±200 (공백 제외)\nconst charCount = text.replace(/\\s/g, '').length;\nif (charCount < 4100 || charCount > 4500) {\n  violations.push({ rule: 'G5_분량', term: `${charCount}자`, count: 1 });\n}\n\n// G6 — 문장 길이: 60자 초과 0건 목표\nconst sentences = text.split(/[.!?]\\s/).filter(s => s.trim().length > 0);\nconst longOnes = sentences.filter(s => s.trim().length > 60);\nconst avgLen = sentences.length\n  ? Math.round(sentences.reduce((a, s) => a + s.trim().length, 0) / sentences.length)\n  : 0;\nif (longOnes.length > 0) {\n  violations.push({ rule: 'G6_문장길이', term: `60자 초과 ${longOnes.length}건`, count: longOnes.length });\n}\n\n// G7 — 문체: 합니다체 통일 ('이야기' 오탐 제외)\nconst casualEndings = (text.match(/(해요\\.|어요\\.|이야\\.|한다\\.|이다\\.)/g) || []).length;\nif (casualEndings > 0) {\n  violations.push({ rule: 'G7_문체', term: '비합니다체 어미', count: casualEndings });\n}\n\nreturn [{\n  json: {\n    passed: violations.length === 0,\n    violationCount: violations.length,\n    charCount,\n    sentenceCount: sentences.length,\n    avgSentenceLength: avgLen,\n    violations,\n    scholarFlags,                        // 게이트1에서 사람이 판단\n    needsReview: scholarFlags.length > 0\n  }\n}];"
      },
