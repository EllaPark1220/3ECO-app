    {
      "parameters": {
        "jsCode": "// 1단 결과\nconst s1 = $('Code in JavaScript').first().json;\n\n// 2단 결과 파싱 (Groq)\nlet s2flags = [];\ntry {\n  const raw = $('2단_Groq스크리닝').first().json.choices[0].message.content;\n  const clean = raw.replace(/```json|```/g, '').trim();\n  s2flags = JSON.parse(clean).flags || [];\n} catch (e) {\n  s2flags = [{ type: 'PARSE_ERROR', sentence: '', reason: '2단 응답 파싱 실패 — 수동 확인 필요' }];\n}\n\n// 3단 결과 파싱 (GPT)\nlet s3 = null;\ntry {\n  const raw = $('3단_GPT검증').first().json.output[0].content[0].text;\n  const clean = raw.replace(/```json|```/g, '').trim();\n  s3 = JSON.parse(clean);\n} catch (e) {\n  s3 = { topic_match: false, issues: ['3단 응답 파싱 실패 — 수동 확인 필요'] };\n}\n\nconst s3failed = !s3.topic_match || !s3.goal1_achieved || !s3.goal2_achieved\n  || !s3.structure_ok || s3.hallucination_found;\n\nconst allPassed = s1.passed && s2flags.length === 0 && !s3failed;\n\nreturn [{\n  json: {\n    passed: allPassed,\n    tier1: { passed: s1.passed, violations: s1.violations, charCount: s1.charCount },\n    tier2: { passed: s2flags.length === 0, flags: s2flags },\n    tier3: { passed: !s3failed, detail: s3 },\n    scholarFlags: s1.scholarFlags,\n    needsReview: s1.needsReview\n  }\n}];"
      },
