# 키 이름만 — 실제 값은 커밋 금지 (PRD §5.3 / CLAUDE.md)
# DB (CT-DB-001)
# DATABASE_URL: 런타임 쿼리용 = Supabase 트랜잭션 풀러(포트 6543).
#   ⚠️ 반드시 끝에 `?pgbouncer=true` 를 붙일 것(파라미터가 이미 있으면 `&pgbouncer=true`).
#   없으면 Prisma named prepared statement 가 풀러에서 충돌 → `prepared statement "s0"
#   already exists`(Postgres 42P05)로 쓰기 실패(SELECT 1 헬스체크는 통과해 놓치기 쉬움).
#   예: postgresql://USER:PASS@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL: 마이그레이션용 = Supabase 세션 풀러(포트 5432). pgbouncer 파라미터 없이.
#   ⚠️ Vercel 배포 env(Production/Preview/Development)에도 DATABASE_URL 에 동일하게
#      `pgbouncer=true` 를 반드시 적용할 것 — 아니면 프로덕션 쓰기가 42P05 로 깨진다.
DATABASE_PROVIDER=postgresql
DATABASE_URL=
DIRECT_URL=

# Supabase (IF-SUP-001 / FW-AUTH-001)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Kakao OAuth (FW-AUTH-006 / grill-it T3)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
