// CT-DB-001 — Prisma 초기화. 모든 후속 DB 모델(CT-DB-002~011)의 기반.
// D7(CORE): Prisma 는 provider 를 정적 리터럴로만 허용(env() 불가). SRS C-TEC-003 의
// "SQLite 로컬 ↔ PostgreSQL 배포 단일 스키마(env provider)" 는 Prisma 제약상 불가하므로,
// 로컬·배포 모두 PostgreSQL(로컬은 Supabase local/Docker) 단일 provider 로 확정.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // 마이그레이션 직접 연결 (Supabase PgBouncer 우회)
}

generator client {
  provider = "prisma-client-js"
}

// 모델은 CT-DB-002~011 에서 추가된다.

// ── CT-DB-002 · User + 환경설정 enum ─────────────────────────────
// PII 최소(REQ-NF-014): email·nickname 만 수집. 성명·연락처·주소·생년월일·
// 결제·소득 컬럼은 영구 금지(CON-01/02). 근거: SRS §6.2.2 USER 엔터티
// (accessibility_mode·media_preference) + T5 CORE 결정(FontSize enum).
// colorMode 는 SRS 데이터 모델 근거 부재 + 다크모드 연기(PROJECT_DECISIONS §4.4)
// 로 제외 — 다크모드 확정 시(FR-AUTH-003) 별도 마이그레이션으로 추가.
// relation(lessonProgress/stamps/teacherFeedbacks/eventLogs)은 대상 모델
// (CT-DB-004/005/007/009) 생성 시 back-reference 와 함께 추가.

enum Role {
  LEARNER
  TEACHER
  ADMIN
}

enum MediaPreference {
  VIDEO
  TEXT
  MIXED
}

enum FontSize {
  XS // 14px
  S // 18px (default)
  L // 22px
  XL // 28px
}

/// RLS(CT-DB-011): ENABLE + user_select_self(authenticated, auth.uid()::text=id). 쓰기 정책 없음(서버 Prisma 전담).
/// RLS 는 schema 에 미모델링 → migrations/20260709235613_enable_rls_ct_db_011 참조.
model User {
  id                String          @id @default(uuid()) // = Supabase auth.users.id
  email             String          @unique
  nickname          String          @db.VarChar(40)
  role              Role            @default(LEARNER)
  accessibilityMode Boolean         @default(false)
  mediaPreference   MediaPreference @default(MIXED)
  fontSize          FontSize        @default(S)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // back-relation (CT-DB-004). 나머지 relation(stamps/teacherFeedbacks/eventLogs)은 각 모델 착수 시 추가.
  lessonProgresses LessonProgress[]

  @@index([role])
  @@index([createdAt])
}

// ── CT-DB-003 · Lesson (최소 stub) ───────────────────────────────
// W11(학습 진척 영속화)에 필요한 최소 필드만. 본편·차시·권 메타(module/order/quarter 등)는
// FR-LESSON 계열 착수 시 확장. lessonId 는 L001~L133 포맷·고유·불변(CLAUDE.md T1).
/// RLS(CT-DB-011): ENABLE + lesson_select_public(anon+authenticated USING true). 콘텐츠 공개 읽기.
model Lesson {
  lessonId  String   @id // L001~L133
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progresses LessonProgress[]
}

// ── CT-DB-004 · LessonProgress (재생 위치 영속화) ─────────────────
// W11 핵심: lastPositionSec 저장/재개. oxCompleted·stampEarned 는 컬럼만 존재하고
// 이 웨이브에서는 쓰지 않는다(OX/Stamp 채점은 별도 task). INV-04 무결성:
// stampEarned=true 이면 oxCompleted=true 여야 함 → migration.sql 에 CHECK 제약 수기 추가.
// IDOR: userId 는 세션에서만 채움(요청 입력 user_id 미사용). @@unique 로 (user,lesson) 1행.
/// RLS(CT-DB-011): ENABLE + progress_select_self(authenticated, auth.uid()::text="userId"). 쓰기 정책 없음(서버 Prisma 전담).
model LessonProgress {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId        String
  lesson          Lesson   @relation(fields: [lessonId], references: [lessonId], onDelete: Cascade)
  lastPositionSec Int      @default(0)
  oxCompleted     Boolean  @default(false)
  stampEarned     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}
